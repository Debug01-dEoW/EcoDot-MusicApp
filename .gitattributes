# GitHub Linguist overrides - force language detection

# Kotlin
*.kt linguist-language=Kotlin
*.kts linguist-language=Kotlin

# Force XML to be counted as a detectable language
*.xml linguist-detectable=true
*.xml linguist-language=XML

# TOML - Gradle version catalog
*.toml linguist-detectable=true
*.toml linguist-language=TOML

# Properties files
*.properties linguist-detectable=true
*.properties linguist-language=INI

# Exclude binary/vendored files from language stats
*.apk linguist-vendored=true
*.ttf linguist-vendored=true
*.webp linguist-vendored=true
*.png linguist-vendored=true
*.jar linguist-vendored=true
gradlew linguist-vendored=true
gradlew.bat linguist-vendored=true
gradle/wrapper/** linguist-vendored=true
